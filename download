<style>
:root{
  --ink:#15161B; --panel:#1E2027; --panel2:#24262F; --line:#2E3138;
  --text:#ECE7DB; --muted:#9A968C; --faint:#6E6B64;
  --gold:#E8B84B; --gold-dim:#B8923A; --cool:#7FB0AA; --cool-soft:rgba(127,176,170,.12);
  --danger:#CF6A5E;
  --disp:'Oswald',Impact,'Arial Narrow',sans-serif;
  --body:'Inter',system-ui,-apple-system,Segoe UI,Arial,sans-serif;
}
*{box-sizing:border-box} html,body{margin:0;padding:0}
body{background:var(--ink);color:var(--text);font-family:var(--body);font-size:15px;line-height:1.5;
  -webkit-font-smoothing:antialiased;background-image:radial-gradient(140% 80% at 50% -10%, #1c1d24 0%, var(--ink) 60%);min-height:100vh}
.wrap{max-width:1080px;margin:0 auto;padding:0 20px 80px}
.tnum{font-variant-numeric:tabular-nums}
button{font-family:inherit;cursor:pointer}
button:focus-visible,[tabindex]:focus-visible,input:focus-visible,select:focus-visible{outline:2px solid var(--gold);outline-offset:2px;border-radius:4px}
header.marquee{padding:30px 0 18px;border-bottom:1px solid var(--line);margin-bottom:18px}
.bulbs{display:flex;gap:9px;margin-bottom:16px}
.bulbs span{width:7px;height:7px;border-radius:50%;background:var(--gold-dim);box-shadow:0 0 7px 1px rgba(232,184,75,.5)}
.bulbs span:nth-child(odd){background:var(--gold);box-shadow:0 0 10px 2px rgba(232,184,75,.65)}
.wordmark{font-family:var(--disp);font-weight:700;letter-spacing:.06em;font-size:clamp(30px,5vw,46px);line-height:.98;text-transform:uppercase;margin:0}
.wordmark .yr{color:var(--gold)}
.kicker{font-family:var(--disp);text-transform:uppercase;letter-spacing:.32em;font-size:12px;color:var(--muted);font-weight:500;margin:0 0 10px}
.lede{color:var(--muted);max-width:64ch;margin:10px 0 0}
.bar{display:flex;flex-wrap:wrap;gap:14px;align-items:center;justify-content:space-between;margin:18px 0 20px}
.tabs{display:flex;gap:4px;background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:4px}
.tabs button{background:transparent;border:0;color:var(--muted);padding:8px 16px;border-radius:7px;font-family:var(--disp);text-transform:uppercase;letter-spacing:.1em;font-size:13px;font-weight:500}
.tabs button.on{background:var(--panel2);color:var(--text)}
.tabs button .pip{display:inline-block;margin-left:7px;color:var(--cool);font-weight:700}
.namefield{display:flex;align-items:center;gap:9px;color:var(--muted);font-size:13px}
.namefield .lab{font-family:var(--disp);text-transform:uppercase;letter-spacing:.14em;font-size:11px}
input[type=text],input[type=password]{background:var(--ink);border:1px solid var(--line);color:var(--text);border-radius:9px;padding:9px 12px;font-size:14px;font-family:inherit}
.namefield input{width:170px}
.namefield input.need{border-color:var(--gold);box-shadow:0 0 0 2px rgba(232,184,75,.25)}
.btn{background:var(--gold);color:#1a1407;border:0;border-radius:9px;padding:11px 18px;font-family:var(--disp);text-transform:uppercase;letter-spacing:.08em;font-weight:600;font-size:13.5px}
.btn:hover{background:#f1c560}
.btn.ghost{background:transparent;color:var(--text);border:1px solid var(--line)}
.btn.ghost:hover{border-color:var(--gold);color:var(--gold)}
.btn.cool{background:var(--cool);color:#0d1413} .btn.cool:hover{background:#94c0bb}
.btn.danger{background:transparent;border:1px solid var(--danger);color:var(--danger)}
.btn.danger:hover{background:rgba(207,106,94,.12)}
.btn:disabled{opacity:.45;cursor:not-allowed}
.btn.sm{padding:8px 13px;font-size:12px}
.toolbar{display:flex;flex-wrap:wrap;gap:12px;align-items:center;justify-content:space-between;background:var(--panel);border:1px solid var(--line);border-radius:12px;padding:12px 14px;margin-bottom:8px;position:sticky;top:0;z-index:30}
.toolbar .grp{display:flex;gap:10px;align-items:center;flex-wrap:wrap}
.toolbar input[type=text]{width:190px}
.toolbar select{background:var(--ink);border:1px solid var(--line);color:var(--text);border-radius:9px;padding:9px 12px;font-size:13.5px;font-family:inherit}
.toolbar .lab{font-family:var(--disp);text-transform:uppercase;letter-spacing:.14em;font-size:11px;color:var(--muted)}
.status{font-size:12.5px;color:var(--muted);display:flex;align-items:center;gap:7px}
.status .dot{width:8px;height:8px;border-radius:50%;background:var(--gold)}
.status.done .dot{background:var(--cool)}
.hint{color:var(--faint);font-size:12.5px;margin:10px 2px 14px}
.list{display:flex;flex-direction:column;gap:8px;margin-top:6px}
.card{display:grid;grid-template-columns:64px 1fr auto;gap:14px;align-items:start;background:var(--panel);border:1px solid var(--line);border-radius:12px;padding:14px;transition:border-color .12s,box-shadow .12s}
.card.drag{opacity:.4} .card.over{border-color:var(--gold);box-shadow:0 0 0 1px var(--gold) inset}
.card .rank{font-family:var(--disp);font-weight:700;font-size:34px;color:var(--gold);line-height:1;text-align:center;padding-top:2px;cursor:grab;user-select:none}
.card .rank small{display:block;font-size:9px;letter-spacing:.18em;color:var(--faint);font-weight:500;margin-top:3px}
.body{min-width:0}
.title{font-family:var(--disp);font-weight:600;font-size:19px;letter-spacing:.01em;margin:0}
.title .y{color:var(--muted);font-weight:400;font-size:15px;margin-left:6px}
.desc{color:var(--muted);font-size:13.5px;margin:5px 0 0;cursor:pointer;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.desc.open{-webkit-line-clamp:unset}
.meta{display:flex;flex-wrap:wrap;gap:6px;margin-top:10px}
.chip{font-size:11.5px;color:var(--muted);background:var(--ink);border:1px solid var(--line);border-radius:999px;padding:3px 9px;display:inline-flex;gap:5px;align-items:center}
.chip b{color:var(--text);font-weight:600}
.chip .k{font-family:var(--disp);text-transform:uppercase;letter-spacing:.1em;font-size:9.5px;color:var(--faint)}
.ctrls{display:flex;flex-direction:column;gap:6px;align-items:flex-end}
.ctrls .row{display:flex;gap:6px}
.mv{width:32px;height:30px;background:var(--ink);border:1px solid var(--line);color:var(--text);border-radius:7px;font-size:14px;display:flex;align-items:center;justify-content:center;line-height:1}
.mv:hover{border-color:var(--gold);color:var(--gold)}
.jump{display:flex;gap:5px;align-items:center}
.jump input{width:52px;text-align:center;padding:6px;font-size:13px;background:var(--ink);border:1px solid var(--line);color:var(--text);border-radius:7px;font-family:inherit}
.panel{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:20px;margin-bottom:16px}
