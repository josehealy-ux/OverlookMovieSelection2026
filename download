async function api(p,opts){
  const r=await fetch(p,Object.assign({headers:{'Content-Type':'application/json'}},opts||{}));
  if(!r.ok){ let m='Something went wrong'; try{m=(await r.json()).error||m;}catch(e){} const err=new Error(m); err.status=r.status; throw err; }
  return r.json();
}

function sortResults(results){
  return results.slice().sort((a,b)=>{
    if(a.n===0&&b.n===0) return a.id-b.id;
    if(a.n===0) return 1; if(b.n===0) return -1;
    if(a.avg!==b.avg) return a.avg-b.avg;
    if(a.firsts!==b.firsts) return b.firsts-a.firsts;
    if(a.median!==b.median) return a.median-b.median;
    return (byId[b.id].imdb||0)-(byId[a.id].imdb||0);
  });
}

/* ---- shell ---- */
function render(){
  const app=document.getElementById('app');
  app.innerHTML = headerHTML() + barHTML() + (state.mode==='vote'?voteHTML():resultsHTML());
  if(state.mode==='vote') wireVote(); else wireResults();
}
function headerHTML(){
  return `<header class="marquee">
    <div class="bulbs">${'<span></span>'.repeat(11)}</div>
    <p class="kicker">Selection Committee · Programmer's Ballot</p>
    <h1 class="wordmark">Overlook <span class="yr">2026</span></h1>
    <p class="lede">${state.mode==='vote'
      ? `Drag the ${N} films into your order — number 1 is your top pick — then hit <b>Submit my ranking</b>. Enter the same name later to update it.`
      : `The committee's live combined ranking, updating as ballots come in.`}</p>
  </header>`;
}
function barHTML(){
  const right = state.mode==='vote'
    ? `<div class="namefield"><span class="lab">Your name</span><input type="text" id="vname" maxlength="40" placeholder="e.g. Jordan" value="${esc(state.voterName)}" autocomplete="off"></div>`
    : `<div class="namefield"><span class="lab">${state.server?state.server.count:0} ballot${state.server&&state.server.count===1?'':'s'} in</span></div>`;
  const pip = state.server&&state.server.count? `<span class="pip">${state.server.count}</span>`:'';
  return `<div class="bar">
    <div class="tabs">
      <button id="m-vote" class="${state.mode==='vote'?'on':''}">Rank the slate</button>
      <button id="m-res" class="${state.mode==='results'?'on':''}">The room's verdict${pip}</button>
    </div>${right}
  </div>`;
}

/* ---- vote ---- */
const SEEDS={current:'Keep current order',imdb:'IMDb score (high→low)',rtc:'RT Critics (high→low)',rta:'RT Audience (high→low)',az:'Title A→Z',shuffle:'Shuffle'};
function voteHTML(){
  const opts=Object.entries(SEEDS).map(([k,v])=>`<option value="${k}">${v}</option>`).join('');
  const st = state.submitted
    ? `<span class="status done"><span class="dot"></span>Submitted ${fmtTime(state.submittedAt)} — re-submit to update</span>`
    : `<span class="status"><span class="dot"></span>Not submitted yet</span>`;
  return `<div class="toolbar">
    <div class="grp">
      <input type="text" id="filter" placeholder="Find a film…" value="${esc(state.filter)}">
      <span class="lab">Start from</span><select id="seed">${opts}</select>
    </div>
    <div class="grp">${st}<button class="btn" id="submit" ${state.busy?'disabled':''}>${state.submitted?'Update my ranking':'Submit my ranking'}</button></div>
  </div>
  <p class="hint">Drag a card by its rank number, use ▲ ▼ ⤒ ⤓, or type a new position.${state.filter?' <b style="color:var(--gold)">Filtered — clear the search box to drag-reorder.</b>':''}</p>
  <div class="list" id="list">${state.order.map((id,i)=>cardHTML(byId[id],i)).join('')}</div>`;
}
function cardHTML(f,i){
  if(state.filter && !f.title.toLowerCase().includes(state.filter.toLowerCase())) return '';
  const drag = state.filter? '' : 'draggable="true"';
  return `<div class="card" data-id="${f.id}" ${drag}>
    <div class="rank" title="Drag to reorder">${i+1}<small>RANK</small></div>
    <div class="body">
      <p class="title">${esc(f.title)}<span class="y">${esc(f.year)}</span></p>
      <p class="desc" title="Click to expand">${esc(f.desc)}</p>
      <div class="meta">
        <span class="chip"><span class="k">Run</span><b>${fmtNum(f.runtime)} min</b></span>
        <span class="chip"><span class="k">IMDb</span><b>${fmtNum(f.imdb)}</b></span>
        <span class="chip"><span class="k">RT Crit</span><b>${fmtNum(f.rtCritics,'%')}</b></span>
        <span class="chip"><span class="k">RT Aud</span><b>${fmtNum(f.rtAudience,'%')}</b></span>
        <span class="chip"><span class="k">Ratings</span><b>${esc(f.rtRatings||'—')}</b></span>
      </div>
    </div>
    <div class="ctrls">
      <div class="row">
        <button class="mv" data-act="top" title="Move to top">⤒</button>
        <button class="mv" data-act="up" title="Up">▲</button>
        <button class="mv" data-act="down" title="Down">▼</button>
        <button class="mv" data-act="bottom" title="Move to bottom">⤓</button>
      </div>
      <div class="jump"><span class="lab" style="font-size:10px;color:var(--faint)">to&nbsp;#</span>
        <input type="text" inputmode="numeric" class="jin" value="${i+1}" aria-label="Set rank for ${esc(f.title)}"></div>
    </div>
  </div>`;
}
function move(id,act){const a=state.order,from=a.indexOf(id);if(from<0)return;a.splice(from,1);
  if(act==='top')a.unshift(id);else if(act==='bottom')a.push(id);
  else if(act==='up')a.splice(Math.max(0,from-1),0,id);else if(act==='down')a.splice(Math.min(a.length,from+1),0,id);
  renderListOnly();}
function moveTo(id,pos){const a=state.order,from=a.indexOf(id);if(from<0)return;let to=Math.max(1,Math.min(N,pos))-1;a.splice(from,1);a.splice(to,0,id);renderListOnly();}
function reorderDrag(src,tgt,after){const a=state.order,from=a.indexOf(src);if(from<0)return;a.splice(from,1);let to=a.indexOf(tgt);if(to<0){a.splice(from,0,src);return;}a.splice(after?to+1:to,0,src);renderListOnly();}
function renderListOnly(){const list=document.getElementById('list');if(!list)return;list.innerHTML=state.order.map((id,i)=>cardHTML(byId[id],i)).join('');wireList();}
function wireVote(){
  document.getElementById('m-vote').onclick=()=>switchMode('vote');
  document.getElementById('m-res').onclick=()=>switchMode('results');
  const vn=document.getElementById('vname');
  vn.oninput=()=>{state.voterName=vn.value;};
  vn.onblur=()=>maybeLoadMine();
  const f=document.getElementById('filter'); f.oninput=()=>{state.filter=f.value;renderListOnly();};
  document.getElementById('seed').onchange=e=>{seed(e.target.value);e.target.value='current';};
  document.getElementById('submit').onclick=submit;
  wireList();
}
function wireList(){
  const list=document.getElementById('list');
  list.querySelectorAll('.card').forEach(card=>{
    const id=parseInt(card.dataset.id);
    card.querySelectorAll('.mv').forEach(b=>b.onclick=()=>move(id,b.dataset.act));
    const jin=card.querySelector('.jin');
    if(jin){jin.onkeydown=e=>{if(e.key==='Enter'){const v=parseInt(e.target.value);if(v>=1&&v<=N)moveTo(id,v);}};
      jin.onblur=e=>{const v=parseInt(e.target.value);if(v>=1&&v<=N&&v!==state.order.indexOf(id)+1)moveTo(id,v);};}
    const d=card.querySelector('.desc'); if(d)d.onclick=()=>d.classList.toggle('open');
    if(card.getAttribute('draggable')==='true'){
      card.addEventListener('dragstart',e=>{card.classList.add('drag');e.dataTransfer.setData('text/plain',id);e.dataTransfer.effectAllowed='move';});
      card.addEventListener('dragend',()=>{card.classList.remove('drag');list.querySelectorAll('.over').forEach(c=>c.classList.remove('over'));});
      card.addEventListener('dragover',e=>{e.preventDefault();card.classList.add('over');e.dataTransfer.dropEffect='move';autoScroll(e.clientY);});
      card.addEventListener('dragleave',()=>card.classList.remove('over'));
      card.addEventListener('drop',e=>{e.preventDefault();card.classList.remove('over');const src=parseInt(e.dataTransfer.getData('text/plain'));if(src===id)return;const rect=card.getBoundingClientRect();reorderDrag(src,id,(e.clientY-rect.top)>rect.height/2);});
    }
  });
}
let scrollRAF=null;
function autoScroll(y){const m=90,sp=14;if(scrollRAF)cancelAnimationFrame(scrollRAF);scrollRAF=requestAnimationFrame(()=>{if(y<m)window.scrollBy(0,-sp);else if(y>window.innerHeight-m)window.scrollBy(0,sp);});}
function seed(kind){if(kind==='current')return;let a=[...FILMS];
  if(kind==='imdb')a.sort((x,y)=>(y.imdb||0)-(x.imdb||0));
  else if(kind==='rtc')a.sort((x,y)=>(y.rtCritics||0)-(x.rtCritics||0));
  else if(kind==='rta')a.sort((x,y)=>(y.rtAudience||0)-(x.rtAudience||0));
  else if(kind==='az')a.sort((x,y)=>x.title.localeCompare(y.title));
  else if(kind==='shuffle'){for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}}
  state.order=a.map(f=>f.id);renderListOnly();}
async function maybeLoadMine(){
  const name=state.voterName.trim(); if(!name) return;
  const id=slug(name); if(id===state.lastLoaded) return; state.lastLoaded=id;
  try{ const b=await api('/api/ballot/'+encodeURIComponent(id));
    if(b&&Array.isArray(b.order)&&b.order.length===N){ state.order=b.order.slice(); state.submitted=true; state.submittedAt=b.submittedAt; render(); toast('Loaded your saved ranking — edit and re-submit to update'); }
  }catch(e){ /* 404 = no prior ballot; fine */ }
}
async function submit(){
  const name=state.voterName.trim();
  if(!name){const vn=document.getElementById('vname');vn.classList.add('need');vn.focus();toast('Add your name first',true);return;}
  state.busy=true; render();
  try{
    const r=await api('/api/ballot',{method:'POST',body:JSON.stringify({name,order:state.order})});
    state.submitted=true; state.submittedAt=Date.now(); state.busy=false; state.lastLoaded=r.voterId;
    toast('Ballot submitted'); await switchMode('results');
  }catch(e){ state.busy=false; render(); toast(e.message||'Could not submit',true); }
}

/* ---- results ---- */
function resultsHTML(){
  const s=state.server;
  if(!s) return `<div class="panel"><div class="empty">Loading the latest tally…</div></div>`;
  const sorted=sortResults(s.results).filter(r=>r.n>0);
  const V=s.count;
  let lb;
  if(V===0){ lb=`<div class="empty"><b>No ballots yet.</b><br>As committee members submit, the combined ranking appears here.</div>`; }
  else{
    const head=`<div class="rrow head"><span>#</span><span>Film</span><span>Rank spread (best→worst)</span><span style="text-align:right">Avg rank</span></div>`;
    const body=sorted.map((r,i)=>{const f=byId[r.id];
      const lo=((r.best-1)/(N-1))*100,hi=((r.worst-1)/(N-1))*100,av=((r.avg-1)/(N-1))*100;
      return `<div class="rrow"><div class="orank">${i+1}</div>
        <div class="rtitle">${esc(f.title)}<span class="y">${esc(f.year)}</span>
          <small>${r.n} ballot${r.n>1?'s':''} · ${r.firsts?`${r.firsts}× #1 · `:''}median ${r.median}</small></div>
        <div class="spread-wrap"><div class="spread"><div class="fill" style="left:${lo}%;right:${100-hi}%"></div><div class="avg" style="left:${av}%"></div></div>
          <div class="spread-lab"><span>#${r.best}</span><span>#${r.worst}</span></div></div>
        <div class="avgnum tnum">${r.avg.toFixed(2)}<small>of ${N}</small></div></div>`;}).join('');
    lb=`<div class="rtable">${head}${body}</div>`;
  }
  const me=slug(state.voterName);
  const voters=s.voters.map(v=>`<span class="vchip ${slug(v.name)===me&&state.voterName?'me':''}"><span class="d"></span>${esc(v.name)} <time>${fmtTime(v.submittedAt)}</time>${state.adminKey?`<button data-rm="${esc(slug(v.name))}" title="Remove">×</button>`:''}</span>`).join('');
  return `<div class="panel">
      <h3>Who's in</h3>
      <p class="sub">Updates automatically every few seconds.</p>
      <div class="voters">${voters||'<span class="sub">No one yet.</span>'}</div>
      <div class="codeacts"><button class="btn ghost" id="backRank">Back to my ranking</button>${V?'<button class="btn cool" id="exportCsv">Export CSV for Excel</button>':''}</div>
    </div>
    <div class="panel">
      <h3>The room's verdict</h3>
      <p class="sub">Combined ranking by average position across ${V} ballot${V===1?'':'s'} (lower is better — equivalent to a Borda count). Gold tick = average; band = best-to-worst spread.</p>
      ${lb}
    </div>
    <div class="panel" style="border-style:dashed">
      <h3 style="font-size:15px">Organizer controls</h3>
      <p class="sub" style="margin-bottom:10px">Enter the admin key (the one set on the server) to remove a ballot or clear the round. Voters don't need this.</p>
      <div class="adminrow">
        <input type="password" id="adminKey" placeholder="Admin key" value="${esc(state.adminKey)}" style="width:200px">
        <button class="btn ghost" id="saveKey">Use key</button>
        ${state.adminKey&&V?'<button class="btn danger" id="clearAll">Clear all ballots</button>':''}
      </div>
    </div>
    <p class="foot">Average rank and Borda points give the same order when every ballot ranks all ${N} films, so this shows the average for readability. Ties break by more #1 placements, then lower median, then higher IMDb. The server stores rankings but only ever shows the combined result and the list of names — never how any individual ranked.</p>`;
}
function wireResults(){
  document.getElementById('m-vote').onclick=()=>switchMode('vote');
  document.getElementById('m-res').onclick=()=>switchMode('results');
  document.getElementById('backRank').onclick=()=>switchMode('vote');
  const ex=document.getElementById('exportCsv'); if(ex) ex.onclick=exportCSV;
  const sk=document.getElementById('saveKey'); if(sk) sk.onclick=()=>{state.adminKey=document.getElementById('adminKey').value.trim();render();toast(state.adminKey?'Admin key set':'Admin key cleared');};
  const ca=document.getElementById('clearAll'); if(ca) ca.onclick=clearAll;
  document.querySelectorAll('[data-rm]').forEach(b=>b.onclick=()=>removeBallot(b.dataset.rm));
}
async function fetchState(rerender){
  try{ const s=await api('/api/state');
    const changed = JSON.stringify(state.server)!==JSON.stringify(s);
    state.server=s; if(rerender||changed) render();
  }catch(e){ if(rerender) render(); }
}
function startPoll(){ stopPoll(); poll=setInterval(()=>{ if(state.mode==='results') fetchState(false); },5000); }
function stopPoll(){ if(poll){clearInterval(poll);poll=null;} }
async function removeBallot(voterId){
  if(!confirm('Remove this ballot?')) return;
  try{ await api('/api/admin/remove',{method:'POST',headers:{'Content-Type':'application/json','x-admin-key':state.adminKey},body:JSON.stringify({voterId})});
    await fetchState(true); toast('Ballot removed');
  }catch(e){ toast(e.message,true); }
}
async function clearAll(){
  if(!confirm('Clear EVERYONE\'s ballots? This cannot be undone.')) return;
  try{ await api('/api/admin/clear',{method:'POST',headers:{'Content-Type':'application/json','x-admin-key':state.adminKey},body:JSON.stringify({})});
    await fetchState(true); toast('All ballots cleared');
  }catch(e){ toast(e.message,true); }
}
function exportCSV(){
  const sorted=sortResults(state.server.results).filter(r=>r.n>0);
  if(!sorted.length){toast('No ballots to export',true);return;}
  const cols=['Overall Rank','Title','Year','Avg Rank','Ballots','Best','Worst','Median','#1 Votes','Runtime (min)','IMDb (/10)','RT Critics (%)','RT Audience (%)','RT Audience ratings'];
  const q=v=>{v=(v==null?'':String(v));return /[",\n]/.test(v)?'"'+v.replace(/"/g,'""')+'"':v;};
  const lines=[cols.map(q).join(',')];
  sorted.forEach((r,i)=>{const f=byId[r.id];lines.push([i+1,f.title,f.year,r.avg.toFixed(2),r.n,r.best,r.worst,r.median,r.firsts,f.runtime,f.imdb,f.rtCritics,f.rtAudience,f.rtRatings].map(q).join(','));});
  const blob=new Blob(['\ufeff'+lines.join('\r\n')],{type:'text/csv;charset=utf-8'});
  const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download='Overlook_2026_combined_ranking.csv';
  document.body.appendChild(a);a.click();a.remove();URL.revokeObjectURL(url);toast('CSV downloaded');
}
async function switchMode(m){
  state.mode=m; window.scrollTo({top:0,behavior:'smooth'});
  if(m==='results'){ render(); await fetchState(true); startPoll(); }
  else { stopPoll(); render(); }
}
let toastTimer=null;
function toast(msg,err){let t=document.querySelector('.toast');if(t)t.remove();t=document.createElement('div');t.className='toast'+(err?' err':'');t.textContent=msg;document.body.appendChild(t);clearTimeout(toastTimer);toastTimer=setTimeout(()=>t.remove(),2800);}
render();
</script>
</body>
</html>