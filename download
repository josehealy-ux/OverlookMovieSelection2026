.voters{display:flex;flex-wrap:wrap;gap:8px}
.vchip{display:inline-flex;align-items:center;gap:8px;background:var(--ink);border:1px solid var(--line);border-radius:999px;padding:6px 12px;font-size:13px}
.vchip.me{border-color:var(--gold)}
.vchip .d{width:8px;height:8px;border-radius:50%;background:var(--cool)}
.vchip time{color:var(--faint);font-size:11.5px}
.vchip button{background:transparent;border:0;color:var(--faint);font-size:15px;line-height:1;padding:0 0 0 4px}
.vchip button:hover{color:var(--danger)}
.codeacts{display:flex;gap:10px;flex-wrap:wrap;margin-top:12px}
.rtable{display:flex;flex-direction:column;gap:6px;margin-top:4px}
.rrow{display:grid;grid-template-columns:52px 1fr 150px 96px;gap:14px;align-items:center;background:var(--ink);border:1px solid var(--line);border-radius:10px;padding:11px 14px}
.rrow.head{background:transparent;border:0;padding:4px 14px;color:var(--faint)}
.rrow.head span{font-family:var(--disp);text-transform:uppercase;letter-spacing:.12em;font-size:10.5px}
.rrow .orank{font-family:var(--disp);font-weight:700;font-size:26px;color:var(--cool);text-align:center;line-height:1}
.rrow .rtitle{font-family:var(--disp);font-weight:500;font-size:17px}
.rrow .rtitle .y{color:var(--muted);font-weight:400;font-size:13px;margin-left:5px}
.rrow .rtitle small{display:block;color:var(--faint);font-size:11.5px;font-family:var(--body);letter-spacing:0;text-transform:none;margin-top:2px}
.spread{height:8px;background:#15161b;border-radius:5px;position:relative;border:1px solid var(--line)}
.spread .fill{position:absolute;top:-1px;bottom:-1px;background:linear-gradient(90deg,var(--cool-soft),var(--cool));border-radius:5px;opacity:.55}
.spread .avg{position:absolute;top:-3px;width:3px;height:12px;background:var(--gold);border-radius:2px}
.spread-lab{font-size:10.5px;color:var(--faint);margin-top:4px;display:flex;justify-content:space-between}
.avgnum{font-family:var(--disp);font-weight:600;font-size:20px;text-align:right}
.avgnum small{display:block;font-family:var(--body);font-size:10.5px;color:var(--faint);letter-spacing:0;text-transform:none;font-weight:400}
.empty{text-align:center;color:var(--muted);padding:30px 10px} .empty b{color:var(--text)}
.banner{background:rgba(207,106,94,.1);border:1px solid var(--danger);color:#f0b3ab;border-radius:10px;padding:11px 14px;margin:0 0 14px;font-size:13.5px}
.adminrow{display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-top:8px}
.toast{position:fixed;left:50%;bottom:26px;transform:translateX(-50%);background:var(--cool);color:#0d1413;font-weight:600;padding:12px 22px;border-radius:10px;font-size:14px;z-index:80;box-shadow:0 8px 30px rgba(0,0,0,.4)}
.toast.err{background:var(--danger);color:#2a0f0b}
.foot{color:var(--faint);font-size:12px;margin-top:24px;line-height:1.6}
@media (max-width:680px){
  .card{grid-template-columns:48px 1fr;gap:10px}
  .card .ctrls{grid-column:1 / -1;flex-direction:row;justify-content:space-between;align-items:center;border-top:1px solid var(--line);padding-top:10px;margin-top:2px}
  .rrow{grid-template-columns:42px 1fr;gap:10px}
  .rrow .spread-wrap,.rrow .avgnum{grid-column:1 / -1} .rrow .avgnum{text-align:left}
  .toolbar{position:static} .toolbar input[type=text]{width:100%} .namefield input{width:100%}
}
@media (prefers-reduced-motion:reduce){*{transition:none!important}}
</style>
