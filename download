ar": "2010", "desc": "A thief who steals secrets through dreams is hired to plant an idea deep in a target's subconscious.", "runtime": 148, "imdb": 8.8, "rtCritics": 87, "rtAudience": 91, "rtRatings": "250,000+"}, {"id": 39, "title": "Forrest Gump", "year": "1994", "desc": "A kind-hearted Alabama man with a low IQ unwittingly shapes decades of American history.", "runtime": 142, "imdb": 8.8, "rtCritics": 75, "rtAudience": 95, "rtRatings": "250,000+"}, {"id": 40, "title": "Schindler's List", "year": "1993", "desc": "A German businessman saves over a thousand Jewish refugees by employing them. Based on a true story.", "runtime": 195, "imdb": 9, "rtCritics": 98, "rtAudience": 97, "rtRatings": "250,000+"}];
const N = FILMS.length;
